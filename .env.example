# =============================================================================
# AutoGate — sample environment (copy to `.env` and edit)
# Docker Compose auto-loads `.env` for ${VAR} substitution.
# autogate.sh also sources `.env` when present.
# =============================================================================

# --- Locale (OpenVPN filter only; multi ISO2) ---------------------------------
# all = every country. Or ISO2 list: JP | US,JP | US,JP,KR,VN
COUNTRY_FILTER=all
# Psiphon single region (first of COUNTRY_FILTER if set by autogate.sh)
PSIPHON_EGRESS_REGION=

# --- HAProxy egress backends -------------------------------------------------
# all | ovpn | ovpn+psiphon | ovpn+warp | custom
EGRESS_MODE=all
# Used only when EGRESS_MODE=custom:
ENABLE_WARP=1
ENABLE_PROXYBROKER=1
ENABLE_PSIPHON=1
ENABLE_OVPN=1

# --- Dedicated worker ports (1..20 → host 56800..) ---------------------------
PROXY_WORKER_COUNT=10

# --- OpenVPN multi-source refresh --------------------------------------------
# Comma-separated source keys (order = fetch order; pool merge is round-robin).
# Available: local|ovpn-list, vpngate, ipspeed, openproxylist, publicvpnlist
# Comment out any source you do not want, e.g. drop openproxylist on Alpine Docker.
OVPN_SOURCES=vpngate,ipspeed,openproxylist,publicvpnlist

MAX_OVPN_CONFIGS=80
OVPN_REFRESH_SECONDS=1800
OVPN_DEFAULT_USER=vpn
OVPN_DEFAULT_PASS=vpn
# Host path when running refresh outside container (optional)
# OVPN_DIR=./ovpn

# --- Local folder ./ovpn-list (priority when it has *.ovpn) -------------------
# Put your own profiles in ./ovpn-list/*.ovpn
# If present + live-check passes → only these files go to ./ovpn (remote skipped)
OVPN_LIST_DIR=/ovpn-list
OVPN_LIST_PRIORITY=1
OVPN_LIST_LIVE_CHECK=1
# Also live-check remote scrapers (optional, slower)
OVPN_LIVE_CHECK=0
OVPN_LIVE_CHECK_TIMEOUT=3

# --- Worker VPN: failover (always) + optional timed rotate ------------------
# Default OFF: if tunnel is up, keep the same .ovpn. Only switch on down.
# OVPN_ROTATE_ENABLE=1
# ROTATING_DELAY=300
# OVPN_HEALTH_INTERVAL=8
# OVPN_HEALTH_FAILS=2
# OVPN_EGRESS_CHECK=1

# --- Source: IPSpeed ---------------------------------------------------------
IPS_SPEED_MAX=40

# --- Source: OpenProxyList (reCAPTCHA v3 via real browser) --------------------
OPENPROXYLIST_MAX=30
OPENPROXYLIST_MAX_PAGES=2
OPENPROXYLIST_BUDGET_SECONDS=180
OPENPROXYLIST_SORT=sortlast
# auto | playwright | camoufox | off
OPENPROXYLIST_BROWSER=auto
OPENPROXYLIST_HEADLESS=1
# Optional: use installed Chrome instead of bundled Chromium
OPENPROXYLIST_PLAYWRIGHT_CHANNEL=
# Chrome TLS impersonation for list/download HTTP (if curl_cffi installed)
CURL_CFFI_IMPERSONATE=chrome131
# Manual overrides (usually leave empty):
OPENPROXYLIST_RECAPTCHA_TOKEN=
OPENPROXYLIST_IDS=

# --- Source: PublicVPNList (catalog + short-lived token) ---------------------
PUBLICVPNLIST_MAX=20
PUBLICVPNLIST_MAX_PER_COUNTRY=3
PUBLICVPNLIST_BUDGET_SECONDS=90
PUBLICVPNLIST_REQUEST_DELAY=1.0
# 1 = call test_server.php before get_token (slower)
PUBLICVPNLIST_LIVE_CHECK=0
