# AutoGate environment example (copy to .env or export before autogate.sh)

# Locale: empty = all countries; multi ISO2 supported
COUNTRY_FILTER=
# Psiphon single region (autogate.sh sets first country from COUNTRY_FILTER)
PSIPHON_EGRESS_REGION=

# HAProxy rotating backends
# all | ovpn | ovpn+psiphon | ovpn+warp | custom
EGRESS_MODE=all
# Only when EGRESS_MODE=custom:
ENABLE_WARP=1
ENABLE_PROXYBROKER=1
ENABLE_PSIPHON=1
ENABLE_OVPN=1

# OpenVPN multi-source refresh (haproxy container)
OVPN_SOURCES=vpngate,ipspeed
# Optional (not default): openproxylist,publicvpnlist
MAX_OVPN_CONFIGS=80
OVPN_REFRESH_SECONDS=1800
OVPN_DEFAULT_USER=vpn
OVPN_DEFAULT_PASS=vpn

# Per-source caps
IPS_SPEED_MAX=40
OPENPROXYLIST_MAX=30
OPENPROXYLIST_MAX_PAGES=3
OPENPROXYLIST_BUDGET_SECONDS=120
# List needs reCAPTCHA v3 — pick one:
# 1) 2Captcha (recommended for auto)
TWOCAPTCHA_API_KEY=
# 2) Manual short-lived token from browser
OPENPROXYLIST_RECAPTCHA_TOKEN=
# 3) Skip list, download known ids only
OPENPROXYLIST_IDS=
PUBLICVPNLIST_MAX_PER_COUNTRY=10
PUBLICVPNLIST_BUDGET_SECONDS=90
# 1 = probe test_server.php before minting token (slower)
PUBLICVPNLIST_LIVE_CHECK=0

# Dedicated worker ports 56800.. (1-20)
PROXY_WORKER_COUNT=10
