FROM haproxy:2.7.6-alpine
EXPOSE 10000 9999 2087

USER root

RUN apk update \
    && apk --update add python3 py3-pip

ADD proxy/haproxy.cfg /usr/local/etc/haproxy/haproxy.cfg
ADD proxy/vpngate.py /proxy/vpngate.py
ADD proxy/proxy-links-ui.py /proxy/proxy-links-ui.py
ADD proxy/proxy-links-ui.html /proxy/proxy-links-ui.html
ADD proxy/run.sh /proxy/run.sh
RUN chmod +x /proxy/run.sh /proxy/proxy-links-ui.py

CMD ["/proxy/run.sh"]
